{
  "name": "constellation",
  "version": "0.0.0",
  "private": true,
  "description": "A typed, local-first work system for people and external MCP agents.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24.15.0 <27",
    "npm": ">=11.12.1 <12"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "audit:dependencies": "npm audit --audit-level=high",
    "audit:licenses": "node scripts/verify-dependency-licenses.mjs",
    "build": "tsc -b && npm run bundle -w @constellation/mcp && npm run build -w @constellation/desktop-preload && npm run build -w @constellation/desktop-ui",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test",
    "clean": "node scripts/clean.mjs",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint:code && npm run lint:md",
    "lint:code": "eslint . --max-warnings=0",
    "lint:md": "markdownlint-cli2 \"*.md\" \".github/**/*.md\" \"docs/**/*.md\" \"packages/**/*.md\" \"tools/**/*.md\" \"#**/node_modules/**\" \"#AGENTS.md\" \"#dlaczego-notion-zawodzi-i-czego-potrzebuje.md\" \"#docs/plans/**\" \"#docs/specs/**\"",
    "package:alpha": "npm run build && node scripts/desktop/fetch-electron.mjs && node scripts/package-alpha.mjs",
    "package:distribution": "npm run package:alpha && node scripts/package-distribution.mjs",
    "test:alpha:packaged": "node scripts/run-packaged-alpha-smoke.mjs",
    "test:hub:packaged": "node scripts/run-packaged-hub-smoke.mjs",
    "test:distribution:packaged": "node scripts/run-distribution-continuity.mjs",
    "test:scripts": "npm run audit:licenses && node --test scripts/desktop/packaged-credential-store-policy.test.mjs scripts/macos-distribution-signing.test.mjs scripts/prepare-github-release.test.mjs scripts/verify-dependency-licenses.test.mjs",
    "test": "npm run clean && npm run build && npm run test:scripts && node scripts/run-tests.mjs",
    "typecheck": "tsc -b --pretty false"
  },
  "devDependencies": {
    "@electron/notarize": "3.1.1",
    "@electron/osx-sign": "2.5.0",
    "@electron/packager": "20.0.2",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "eslint": "10.7.0",
    "markdownlint-cli2": "0.23.0",
    "node-gyp": "13.0.1",
    "prettier": "3.9.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4"
  }
}
