{
  "name": "constellation",
  "version": "0.0.0",
  "private": true,
  "description": "A typed, local-first work system for people and external MCP agents.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24.15.0 <27",
    "npm": ">=11.12.1 <12"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "audit:dependencies": "npm audit --audit-level=high",
    "build": "tsc -b && npm run build -w @constellation/desktop-ui",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test",
    "clean": "node scripts/clean.mjs",
    "dev:desktop": "npm run dev -w @constellation/desktop-ui",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint:code && npm run lint:md",
    "lint:code": "eslint . --max-warnings=0",
    "lint:md": "markdownlint-cli2 \"*.md\" \".github/**/*.md\" \"docs/**/*.md\" \"packages/**/*.md\" \"tools/**/*.md\" \"#**/node_modules/**\" \"#AGENTS.md\" \"#dlaczego-notion-zawodzi-i-czego-potrzebuje.md\" \"#docs/plans/**\" \"#docs/specs/**\"",
    "test": "npm run clean && npm run build && node scripts/run-tests.mjs",
    "typecheck": "tsc -b --pretty false"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "markdownlint-cli2": "0.23.0",
    "prettier": "3.9.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "43.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4"
  }
}
