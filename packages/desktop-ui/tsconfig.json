{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "outDir": "build/ts",
    "rootDir": ".",
    "tsBuildInfoFile": "build/ts/.tsbuildinfo",
    "types": ["vite/client"]
